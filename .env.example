# =============================================================================
# GuruNote 환경변수 예시 파일
# -----------------------------------------------------------------------------
# 사용법:
#   1) 이 파일을 복사해 `.env` 를 만든다:  cp .env.example .env
#   2) placeholder 값을 본인의 실제 API 키로 교체한다.
#   3) `.env` 는 .gitignore 에 의해 git 에 커밋되지 않는다.
# =============================================================================

# -----------------------------------------------------------------------------
# STT 엔진 선택 (Step 2)
# -----------------------------------------------------------------------------
# vibevoice  : Microsoft VibeVoice-ASR (오픈소스, GPU 권장, API 키 불필요)
# assemblyai : AssemblyAI Cloud API (폴백, API 키 필요)
# auto       : VibeVoice 가능하면 사용, 안되면 AssemblyAI 폴백 (기본값)
GURUNOTE_STT_ENGINE=auto

# VibeVoice 모델 ID (HuggingFace Hub)
VIBEVOICE_MODEL_ID=microsoft/VibeVoice-ASR

# (선택) 비공개/게이트 모델 다운로드 시 HuggingFace 토큰
HUGGINGFACE_TOKEN=

# (선택) AssemblyAI 폴백을 쓸 때만 필요
# https://www.assemblyai.com/
ASSEMBLYAI_API_KEY=

# -----------------------------------------------------------------------------
# LLM Provider (Step 3~4: 번역 / 요약)
# -----------------------------------------------------------------------------
# openai    : gpt-4o
# anthropic : claude-3-5-sonnet
LLM_PROVIDER=openai

# https://platform.openai.com/
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
