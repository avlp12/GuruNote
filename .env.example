# =============================================================================
# GuruNote 환경변수 예시 파일
# -----------------------------------------------------------------------------
# 사용법:
#   1) 이 파일을 복사해 `.env` 를 만든다:  cp .env.example .env
#   2) 아래 placeholder 값을 본인의 실제 API 키로 교체한다.
#   3) `.env` 는 .gitignore 에 의해 git 에 커밋되지 않는다.
# =============================================================================

# AssemblyAI API Key — STT + 화자 분리(Diarization)
# https://www.assemblyai.com/
ASSEMBLYAI_API_KEY=your_assemblyai_api_key_here

# LLM Provider API Keys — 번역/요약용 (둘 중 하나 이상 설정)
# https://platform.openai.com/
OPENAI_API_KEY=your_openai_api_key_here
# https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# 사용할 LLM 제공자 선택: "openai" 또는 "anthropic"
LLM_PROVIDER=openai
