# =============================================================================
# GuruNote 환경변수 예시 파일
# -----------------------------------------------------------------------------
# 사용법:
#   1) 이 파일을 복사해 `.env` 를 만든다:  cp .env.example .env
#   2) placeholder 값을 본인의 실제 API 키로 교체한다.
#   3) `.env` 는 .gitignore 에 의해 git 에 커밋되지 않는다.
# =============================================================================

# -----------------------------------------------------------------------------
# STT 엔진 선택 (Step 2)
# -----------------------------------------------------------------------------
# whisperx   : WhisperX (Distil-Whisper + pyannote 화자 분리, ~6GB VRAM)
# assemblyai : AssemblyAI Cloud API (API 키 필요)
# auto       : WhisperX 우선, 실패 시 AssemblyAI 폴백 (기본값)
GURUNOTE_STT_ENGINE=auto

# WhisperX 모델 (기본: distil-large-v3)
# 다른 옵션: large-v3, medium, small, tiny
WHISPERX_MODEL=distil-large-v3

# WhisperX 배치 사이즈 (VRAM 부족 시 줄이기, 기본 16)
WHISPERX_BATCH_SIZE=16

# HuggingFace 토큰 — pyannote 화자 분리에 필요
# https://huggingface.co/settings/tokens 에서 발급
# pyannote/speaker-diarization-3.1 모델 사용 동의 필요
# (v0.8.0.7+ canonical 이름. 기존 HUGGINGFACE_TOKEN 도 계속 인식됨.)
HF_TOKEN=

# (선택) AssemblyAI 폴백을 쓸 때만 필요
# https://www.assemblyai.com/
ASSEMBLYAI_API_KEY=

# -----------------------------------------------------------------------------
# LLM Provider (Step 3~4: 번역 / 요약)
# -----------------------------------------------------------------------------
# openai             : OpenAI 공식 API
# openai_compatible  : 로컬/사설 OpenAI-compatible API (vLLM, oMLX, Ollama 등)
# anthropic          : Anthropic API
# gemini             : Google Gemini API
LLM_PROVIDER=openai

# https://platform.openai.com/
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-5.4
# 로컬 OpenAI-compatible 서버 사용 시 설정
OPENAI_BASE_URL=

# https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-6

# https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# (선택) 고급 옵션
LLM_TEMPERATURE=0.2
LLM_TRANSLATION_MAX_TOKENS=8192
LLM_SUMMARY_MAX_TOKENS=4096
